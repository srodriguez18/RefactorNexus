datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  password      String
  isAdmin       Boolean        @default(false) @map("is_admin")
  sales         Sale[]
  notifications Notification[]
  refunds       Refund[]

  @@map("users")
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  contact   String?
  country   String?
  products  Product[]
  purchases Purchase[]

  @@map("suppliers")
}

model Warehouse {
  id        Int                 @id @default(autoincrement())
  name      String
  region    String?
  stocks    InventoryStock[]
  movements InventoryMovement[]

  @@map("warehouses")
}

model Product {
  id            Int                 @id @default(autoincrement())
  sku           String              @unique
  name          String
  description   String?
  price         Decimal
  category      String?
  supplierId    Int?                @map("supplier_id")
  supplier      Supplier?           @relation(fields: [supplierId], references: [id])
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")
  stocks        InventoryStock[]
  movements     InventoryMovement[]
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]

  @@map("products")
}

model InventoryStock {
  productId   Int       @map("product_id")
  warehouseId Int       @map("warehouse_id")
  quantity    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([productId, warehouseId])
  @@map("inventory_stock")
}

model InventoryMovement {
  id          Int       @id @default(autoincrement())
  productId   Int       @map("product_id")
  warehouseId Int       @map("warehouse_id")
  quantity    Int       @map("qty")
  type        String
  refId       Int?      @map("ref_id")
  createdAt   DateTime  @default(now()) @map("ts")
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("inventory_movements")
}

// status: 'active' | 'returned' | 'cancelled'
// subtotal and total are Decimal — fixes legacy bug where they were TEXT
model Sale {
  id           Int        @id @default(autoincrement())
  userId       Int        @map("user_id")
  customerType String     @default("NORMAL") @map("customer_type")
  subtotal     Decimal
  discount     Decimal    @default(0)
  total        Decimal
  status       String     @default("active")
  createdAt    DateTime   @default(now()) @map("created_at")
  lastTouchAt  DateTime?  @map("last_touch_at")
  user         User       @relation(fields: [userId], references: [id])
  items        SaleItem[]
  refunds      Refund[]

  @@map("sales")
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int     @map("sale_id")
  productId Int     @map("product_id")
  quantity  Int     @map("qty")
  unitPrice Decimal @map("unit_price")
  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Purchase {
  id           Int            @id @default(autoincrement())
  supplierId   Int            @map("supplier_id")
  total        Decimal
  receivedDate DateTime?      @map("received_date")
  bankRef      String?        @map("bank_ref")
  status       String         @default("pending")
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  productId  Int      @map("product_id")
  quantity   Int      @map("qty")
  unitCost   Decimal  @map("unit_cost")
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  message   String
  kind      String
  status    String   @default("unread")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// amount is Decimal — fixes legacy bug where it was TEXT
// status normalized to 'pending' — legacy had 'pending', 'Pending', 'pendiente'
model Refund {
  id         Int      @id @default(autoincrement())
  saleId     Int      @map("sale_id")
  userId     Int      @map("user_id")
  reason     String
  amount     Decimal
  status     String   @default("pending")
  approvedBy Int?     @map("approved_by")
  createdAt  DateTime @default(now()) @map("created_at")
  sale       Sale     @relation(fields: [saleId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("refunds")
}
